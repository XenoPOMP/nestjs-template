{
  "name": "nestjs-template",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node ./dist/main.js",
    "start:migrate:prod": "npx prisma migrate deploy && yarn start:prod",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "yarn test --watch",
    "test:cov": "yarn test --coverage",
    "test:e2e": "yarn test --config vitest.config.e2e.ts",
    "migrate:dev": "npx prisma migrate dev",
    "postmigrate:dev": "npx prisma generate",
    "studio": "npx prisma studio",
    "prepare": "husky",
    "ci:lint": "yarn lint --max-warnings=0",
    "ci:test": "yarn test --passWithNoTests",
    "pack:env": "tsx ./.dev/scripts/pack-env.ts",
    "knip": "knip -c ./knip.config.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.2.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "7",
    "argon2": "^0.44.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookie-parser": "^1.4.7",
    "dayjs": "^1.11.21",
    "dotenv": "^17.4.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsx": "^4.22.4",
    "xenopomp-essentials": "^0.5.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.1.27",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-istanbul": "4.1.7",
    "ansi-colors": "^4.1.3",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "knip": "^6.17.1",
    "lint-staged": "^16.2.0",
    "prettier": "^3.4.2",
    "prisma": "7",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9",
    "typescript-eslint": "^8.20.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.7"
  },
  "resolutions": {
    "typescript": ">=5.0.0 <6"
  },
  "packageManager": "yarn@1.22.22"
